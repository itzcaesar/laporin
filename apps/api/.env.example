# ═══════════════════════════════════════════════════════════
# Laporin API — Production Environment Variables
# ═══════════════════════════════════════════════════════════
#
# Copy this file to .env and fill in the values:
#
# Credentials are generated by setup scripts and saved to:
#   /home/laporin/.credentials        (PostgreSQL, Redis)
#   /home/laporin/.minio-app-credentials  (MinIO S3)

# ── Database (Self-hosted PostgreSQL) ─────────────────────
# Get DB_PASS from /home/laporin/.credentials
DATABASE_URL="postgresql://laporin:YOUR_DB_PASSWORD@localhost:5432/laporin?schema=public"
DIRECT_URL="postgresql://laporin:YOUR_DB_PASSWORD@localhost:5432/laporin?schema=public"

# ── Redis (Self-hosted) ──────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ── Auth ──────────────────────────────────────────────────
# Generate with: openssl rand -base64 48 | head -c 48
JWT_SECRET="GENERATE-A-RANDOM-STRING-AT-LEAST-32-CHARS-LONG"
JWT_REFRESH_SECRET="GENERATE-ANOTHER-RANDOM-STRING-AT-LEAST-32-CHARS"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ── Storage (Self-hosted MinIO) ──────────────────────────
# Get these from /home/laporin/.minio-app-credentials
S3_ENDPOINT="http://localhost:9000"
S3_REGION="us-east-1"
S3_BUCKET="laporin-media"
S3_ACCESS_KEY="YOUR_MINIO_ACCESS_KEY"
S3_SECRET_KEY="YOUR_MINIO_SECRET_KEY"
S3_PUBLIC_URL="https://media.laporin.site/laporin-media"

# ── AI (OpenRouter or Anthropic) ──────────────────────────
# OpenRouter (supports multiple models including Claude)
OPENROUTER_API_KEY="sk-or-v1-..."
# For backward compatibility
ANTHROPIC_API_KEY="sk-or-v1-..."

# Or use Anthropic directly:
# ANTHROPIC_API_KEY="sk-ant-api03-..."

# ── Email (Resend) ────────────────────────────────────────
SMTP_HOST="smtp.resend.com"
SMTP_PORT=465
SMTP_USER="resend"
SMTP_PASS="re_your_resend_key"
SMTP_FROM="noreply@laporin.site"

# ── WhatsApp (Fonnte) ─────────────────────────────────────
FONNTE_TOKEN="your-fonnte-token"

# ── App ───────────────────────────────────────────────────
PORT=4000
NODE_ENV="production"
ALLOWED_ORIGINS="https://laporin.site,https://www.laporin.site"
