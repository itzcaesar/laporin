# ── Database (Supabase) ──────────────────────────────────
# Connection pooling URL (for application queries via PgBouncer)
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-1-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct connection URL (for migrations - bypasses PgBouncer)
DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-1-ap-southeast-1.pooler.supabase.com:5432/postgres"

# ── Redis ─────────────────────────────────────────────────
# Local Redis
# REDIS_URL="redis://localhost:6379"
# Or Redis Cloud (Upstash, Redis Labs, etc.)
REDIS_URL="redis://default:[PASSWORD]@[HOST]:[PORT]"

# ── Auth ──────────────────────────────────────────────────
JWT_SECRET="min-32-chars-random-string-here"
JWT_REFRESH_SECRET="another-min-32-chars-random-string"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ── Storage (Supabase S3 or Cloudflare R2) ──────────────
# For Supabase Storage:
S3_ENDPOINT="https://[PROJECT-REF].storage.supabase.co"
S3_REGION="ap-southeast-1"
S3_BUCKET="laporin-media"
S3_ACCESS_KEY="your-supabase-s3-access-key"
S3_SECRET_KEY="your-supabase-s3-secret-key"
S3_PUBLIC_URL="https://[PROJECT-REF].supabase.co/storage/v1/object/public/laporin-media"

# For Cloudflare R2 (alternative):
# S3_ENDPOINT="https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com"
# S3_REGION="auto"
# S3_BUCKET="laporin-media"
# S3_ACCESS_KEY="your-r2-access-key"
# S3_SECRET_KEY="your-r2-secret-key"
# S3_PUBLIC_URL="https://media.laporin.site"

# ── AI (OpenRouter or Anthropic) ──────────────────────────
# OpenRouter (supports multiple models including Claude)
OPENROUTER_API_KEY="sk-or-v1-..."
# For backward compatibility
ANTHROPIC_API_KEY="sk-or-v1-..."

# Or use Anthropic directly:
# ANTHROPIC_API_KEY="sk-ant-api03-..."

# ── Email (Resend) ────────────────────────────────────────
SMTP_HOST="smtp.resend.com"
SMTP_PORT=465
SMTP_USER="resend"
SMTP_PASS="re_your_resend_key"
SMTP_FROM="noreply@laporin.site"

# ── WhatsApp (Fonnte) ─────────────────────────────────────
FONNTE_TOKEN="your-fonnte-token"

# ── App ───────────────────────────────────────────────────
PORT=4000
NODE_ENV="development"
ALLOWED_ORIGINS="http://localhost:3000,http://localhost:3001,https://laporin.site"
