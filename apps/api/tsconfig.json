{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@/lib/*": ["./src/lib/*"],
      "@/services/*": ["./src/services/*"],
      "@/middleware/*": ["./src/middleware/*"],
      "@/routes/*": ["./src/routes/*"],
      "@/validators/*": ["./src/validators/*"],
      "@/jobs/*": ["./src/jobs/*"],
      "@/types/*": ["./src/types/*"]
    }
  },
  "include": ["src/**/*", "prisma/**/*", "*.ts", "scratch/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
