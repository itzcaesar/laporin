### Test Report Endpoints
### You can use this file with REST Client extension in VS Code

@baseUrl = http://localhost:4000/api/v1
@accessToken = YOUR_ACCESS_TOKEN_HERE
@reportId = YOUR_REPORT_ID_HERE
@anonymousToken = YOUR_ANONYMOUS_TOKEN_HERE

### 1. Create a new report (authenticated)
POST {{baseUrl}}/reports
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "title": "Jalan berlubang di depan sekolah",
  "description": "Jalan berlubang besar di depan SD Negeri 1, sangat berbahaya untuk anak-anak yang menyeberang. Lubang berdiameter sekitar 1 meter dan kedalaman 30cm.",
  "categoryId": 1,
  "locationLat": -6.9175,
  "locationLng": 107.6191,
  "locationAddress": "Jl. Asia Afrika No. 123, Bandung",
  "regionCode": "3273",
  "regionName": "Kota Bandung",
  "isAnonymous": false
}

### 2. Create anonymous report
POST {{baseUrl}}/reports
Content-Type: application/json

{
  "title": "Lampu jalan mati di Jl. Sudirman",
  "description": "Lampu jalan mati sudah 3 hari, jalan menjadi gelap dan rawan kejahatan di malam hari.",
  "categoryId": 3,
  "locationLat": -6.9147,
  "locationLng": 107.6098,
  "locationAddress": "Jl. Sudirman No. 45, Bandung",
  "regionCode": "3273",
  "regionName": "Kota Bandung",
  "isAnonymous": true
}

### 3. List all reports (public)
GET {{baseUrl}}/reports?page=1&limit=10

### 4. List reports with filters
GET {{baseUrl}}/reports?status=new&categoryId=1&regionCode=3273&page=1&limit=10

### 5. Search reports
GET {{baseUrl}}/reports?search=jalan&page=1&limit=10

### 6. Get report details
GET {{baseUrl}}/reports/{{reportId}}

### 7. Request upload URL for photo
POST {{baseUrl}}/reports/{{reportId}}/media/upload-url
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "mediaType": "photo",
  "mimeType": "image/jpeg",
  "fileSizeBytes": 2048576
}

### 8. Confirm media upload
POST {{baseUrl}}/reports/{{reportId}}/media
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "fileKey": "reports/abc-123/photo/1776157890-uuid.jpg",
  "mediaType": "photo"
}

### 9. Upvote a report
POST {{baseUrl}}/reports/{{reportId}}/vote
Authorization: Bearer {{accessToken}}

### 10. Remove upvote
DELETE {{baseUrl}}/reports/{{reportId}}/vote
Authorization: Bearer {{accessToken}}

### 11. Get comments
GET {{baseUrl}}/reports/{{reportId}}/comments

### 12. Add comment
POST {{baseUrl}}/reports/{{reportId}}/comments
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "content": "Saya juga mengalami hal yang sama di lokasi ini"
}

### 13. Reply to comment
POST {{baseUrl}}/reports/{{reportId}}/comments
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "content": "Terima kasih laporannya, sudah kami tindaklanjuti",
  "parentId": "PARENT_COMMENT_ID"
}

### 14. Get status history
GET {{baseUrl}}/reports/{{reportId}}/status-history

### 15. Rate completed work
POST {{baseUrl}}/reports/{{reportId}}/rating
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "rating": 5,
  "comment": "Perbaikan sangat cepat dan memuaskan!"
}

### 16. Verify completion
POST {{baseUrl}}/reports/{{reportId}}/verify-complete
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "isComplete": true,
  "note": "Pekerjaan sudah selesai dengan baik"
}

### 17. Dispute completion
POST {{baseUrl}}/reports/{{reportId}}/verify-complete
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "isComplete": false,
  "note": "Pekerjaan belum selesai, masih ada lubang kecil"
}
