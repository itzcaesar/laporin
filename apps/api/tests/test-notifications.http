### Test Notification Service
### This file demonstrates how notifications are triggered from route handlers

### Example: Trigger notification when report is submitted
### (This would be called from POST /api/v1/reports route handler)

# In your route handler, after creating a report:
# ```typescript
# import { addNotificationJob } from '../jobs/queue.js'
# 
# // After report creation
# await addNotificationJob({
#   type: 'report_submitted',
#   recipientId: report.reporterId,
#   recipientType: 'citizen',
#   data: {
#     reportId: report.id,
#     trackingCode: report.trackingCode,
#     title: report.title,
#     categoryName: category.name,
#   },
# })
# ```

### Example: Trigger notification when report is verified
# ```typescript
# await addNotificationJob({
#   type: 'report_verified',
#   recipientId: report.reporterId,
#   recipientType: 'citizen',
#   data: {
#     reportId: report.id,
#     trackingCode: report.trackingCode,
#     title: report.title,
#     picName: officer.name,
#     estimatedEnd: report.estimatedEnd?.toLocaleDateString('id-ID'),
#   },
# })
# ```

### Example: Trigger notification when report status changes to in_progress
# ```typescript
# await addNotificationJob({
#   type: 'report_in_progress',
#   recipientId: report.reporterId,
#   recipientType: 'citizen',
#   data: {
#     reportId: report.id,
#     trackingCode: report.trackingCode,
#     title: report.title,
#     estimatedEnd: report.estimatedEnd?.toLocaleDateString('id-ID'),
#   },
# })
# ```

### Example: Trigger notification when report is completed
# ```typescript
# await addNotificationJob({
#   type: 'report_completed',
#   recipientId: report.reporterId,
#   recipientType: 'citizen',
#   data: {
#     reportId: report.id,
#     trackingCode: report.trackingCode,
#     title: report.title,
#     completedAt: new Date().toLocaleDateString('id-ID'),
#   },
# })
# ```

### Example: Trigger notification when citizen disputes a report
# ```typescript
# await addNotificationJob({
#   type: 'report_disputed',
#   recipientId: report.assignedOfficerId,
#   recipientType: 'officer',
#   data: {
#     reportId: report.id,
#     trackingCode: report.trackingCode,
#     title: report.title,
#     disputeNote: disputeData.note,
#   },
# })
# ```

### Example: Trigger notification when SLA is breached
# ```typescript
# // This would typically be triggered by a cron job
# await addNotificationJob({
#   type: 'sla_breached',
#   recipientId: report.assignedOfficerId,
#   recipientType: 'officer',
#   data: {
#     reportId: report.id,
#     trackingCode: report.trackingCode,
#     title: report.title,
#     daysOverdue: 3,
#     priority: report.priority,
#   },
# })
# ```

### Example: Notify officers of new report in their jurisdiction
# ```typescript
# // Get all officers in the agency
# const officers = await db.user.findMany({
#   where: {
#     agencyId: report.agencyId,
#     role: { in: ['officer', 'admin'] },
#     isActive: true,
#   },
# })
# 
# // Notify each officer
# for (const officer of officers) {
#   await addNotificationJob({
#     type: 'new_report_in_jurisdiction',
#     recipientId: officer.id,
#     recipientType: 'officer',
#     data: {
#       reportId: report.id,
#       trackingCode: report.trackingCode,
#       title: report.title,
#       categoryName: category.name,
#       dangerLevel: report.dangerLevel,
#       regionName: report.regionName,
#     },
#   })
# }
# ```

### Notes:
# - All notifications are processed asynchronously via BullMQ
# - Failed notifications will retry 3 times with exponential backoff
# - All notification attempts are logged to the notifications table
# - Email is sent to all users
# - WhatsApp is only sent if user has a phone number
# - Push notifications are sent if user has a push subscription (not yet implemented)
