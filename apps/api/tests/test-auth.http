### Test Auth Endpoints
### You can use this file with REST Client extension in VS Code
### Or copy the curl commands to test manually

@baseUrl = http://localhost:4000/api/v1

### 1. Register a new user
POST {{baseUrl}}/auth/register
Content-Type: application/json

{
  "email": "citizen@test.com",
  "password": "Test1234",
  "name": "Test Citizen"
}

### 2. Login
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "citizen@test.com",
  "password": "Test1234"
}

### 3. Get current user profile (replace TOKEN with accessToken from login)
GET {{baseUrl}}/auth/me
Authorization: Bearer TOKEN

### 4. Refresh token (replace REFRESH_TOKEN with refreshToken from login)
POST {{baseUrl}}/auth/refresh
Content-Type: application/json

{
  "refreshToken": "REFRESH_TOKEN"
}

### 5. Change password (replace TOKEN with accessToken)
PATCH {{baseUrl}}/auth/password/change
Authorization: Bearer TOKEN
Content-Type: application/json

{
  "currentPassword": "Test1234",
  "newPassword": "NewTest1234"
}

### 6. Logout (replace REFRESH_TOKEN with refreshToken)
POST {{baseUrl}}/auth/logout
Content-Type: application/json

{
  "refreshToken": "REFRESH_TOKEN"
}

### 7. Send OTP (requires Redis running)
POST {{baseUrl}}/auth/otp/send
Content-Type: application/json

{
  "email": "citizen@test.com"
}

### 8. Verify OTP (requires Redis running)
POST {{baseUrl}}/auth/otp/verify
Content-Type: application/json

{
  "email": "citizen@test.com",
  "otp": "123456"
}
